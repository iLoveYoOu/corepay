NODE_ENV=production
PORT=4000

# Obrigatório. Gere um segredo longo e aleatório.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Usado somente para criar o Super Admin quando ele ainda não existe.
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=troque-esta-senha

# Ative apenas durante uma rotação administrativa intencional e desligue depois.
ADMIN_FORCE_SYNC=false

# No Render, aponte para o disco persistente montado.
DATABASE_PATH=/var/data/corepay.db

# Um ou mais endereços separados por vírgula. Vazio mantém compatibilidade.
# Exemplo com domínio personalizado:
# CORS_ORIGINS=https://www.meiadolucao.com.br,https://corepay-8b76.onrender.com
CORS_ORIGINS=https://seu-corepay.onrender.com

# Token usado no header Authorization: Bearer <token> para backup.
BACKUP_TOKEN=troque-por-outro-segredo-longo

# Desativado por padrão para evitar tarifas do provedor.
ENABLE_MERCADOPAGO_DEPOSITS=false
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PAYER_EMAIL=
PUBLIC_URL=https://www.meiadolucao.com.br

# Google Sheets — integração de operações financeiras
SPREADSHEET_ID=ID_DA_SUA_PLANILHA
GOOGLE_SERVICE_ACCOUNT_EMAIL=email-da-service-account@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
